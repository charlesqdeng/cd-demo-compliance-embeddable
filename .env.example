# Twilio Configuration
# Get these from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# ISV Configuration
# IMPORTANT: All Twilio toll-free verification notifications (approval/rejection/status updates)
# will be sent to this email address. This should be the ISV's email, NOT the end-customer's email.
# The ISV receives all notifications for verifications submitted through this embeddable form.
ISV_NOTIFICATION_EMAIL=your-isv-email@example.com

# Server Configuration
PORT=3000
NODE_ENV=development
