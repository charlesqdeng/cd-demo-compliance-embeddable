# ====================================================================================
# Twilio Toll-Free Verification - Environment Configuration Sample
# ====================================================================================
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env in the same directory
# 2. Replace the placeholder values with your actual credentials
# 3. Never commit the .env file to git (it's already in .gitignore)
#
# ====================================================================================

# Twilio Configuration
# Get these from: https://console.twilio.com
# Navigate to: Account Dashboard -> Account Info section
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# ISV Configuration
# ====================================================================================
# IMPORTANT: All Twilio toll-free verification notifications will be sent here
# ====================================================================================
# This includes:
#   - Verification approval notifications
#   - Verification rejection notifications with reasons
#   - Status update notifications
#
# FOR ISVs/AGGREGATORS:
#   - Use YOUR company's email address (not your end-customer's)
#   - This email receives ALL verification updates for ALL customers
#   - Example: compliance@your-company.com, notifications@isv.com
#
# FOR DIRECT BUSINESS USE:
#   - Use your business notification email
#   - Example: admin@yourbusiness.com, alerts@company.com
#
ISV_NOTIFICATION_EMAIL=your-isv-email@example.com

# Server Configuration
# Port the web server will listen on (default: 3000)
PORT=3000

# Environment mode: development or production
NODE_ENV=development

# ====================================================================================
# QUICK START:
# ====================================================================================
# 1. cp .env.sample .env
# 2. Edit .env with your actual Twilio credentials
# 3. npm install
# 4. npm start
# 5. Open http://localhost:3000
# ====================================================================================
